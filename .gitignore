# Built-in Gradle/Android Studio ignores
.gradle
/local.properties
/.idea/caches
/.idea/libraries
/.idea/modules.xml
/.idea/workspace.xml
/.idea/navEditor.xml
/.idea/assetWizardSettings.xml
.DS_Store
/build
/captures
.externalNativeBuild
.cxx
/app/build
/app/release/

# Project-specific exclusions (AGENTS.md Section 14)
/logs/
screenshots/
/logs/*.log
!/logs/.gitkeep
/AI/plans/*.draft.md
/keystore.properties
*.jks
d r i d a m . m k v  
 
# Test video fixtures and scratch files (never commit large media)
*.mkv
*.mp4
*.avi
*.mov

# Agent scratch / temporary files
tmp_*
local_*  

# Test artifact directories (databases pulled from device, etc.)
tmp/
# Local release scripts (not committed)
scripts/release-*.ps1
